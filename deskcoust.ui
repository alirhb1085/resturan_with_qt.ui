/* حالت فشرده شدن لحظه‌ای (وقتی کلیک ماوس پایین است) */
QPushButton:pressed {
    background: #afd1e7; /* بنفش تیره */
}

/* حالت انتخاب شده (وقتی دکمه تیک خورده و فشرده باقی مانده است) */
QPushButton:checked {
    image: url(:/new/prefix1/Images/shopping-cart.png);
    background: #afd1e7; /* بنفش تیره */
}</string>
